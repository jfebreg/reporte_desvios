PORT=8787
APP_ORIGIN=http://localhost:4181
API_TOKEN=CAMBIAR_POR_TOKEN_LARGO
AUTO_IMPORT_MINUTES=15
AUTO_REMINDER_MINUTES=1440
DATABASE_URL=
DATABASE_SSL=true

# Correo real opcional via SendGrid. Si queda vacio, los correos se simulan en la bandeja.
SENDGRID_API_KEY=
MAIL_FROM=prevencion@empresa.cl

# Google Sheets API con cuenta de servicio
GOOGLE_SHEET_ID=
GOOGLE_SHEET_RANGE=Respuestas de formulario 1!A:Z
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Alternativa: ruta a JSON descargado desde Google Cloud
GOOGLE_SERVICE_ACCOUNT_JSON=
